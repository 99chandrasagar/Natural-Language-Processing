# Copy this to .env and fill in your values

# LLM Provider: openai | anthropic | ollama
LLM_PROVIDER=openai

# API Keys (only need the one matching your provider)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model override (optional — defaults are set per provider)
# LLM_MODEL=gpt-4o-mini

# Ollama (only if using local models)
# OLLAMA_BASE_URL=http://localhost:11434

# LLM settings
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2
